AddDefaultCharset UTF-8

# ---- HTTPS + www -> apex yonlendirme ----
RewriteEngine On
# Let's Encrypt / AutoSSL dogrulamasini yonlendirme disinda tut
RewriteCond %{REQUEST_URI} ^/\.well-known/acme-challenge/ [NC]
RewriteRule ^ - [L]
# HTTP -> HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://tavukcadiri.com%{REQUEST_URI} [L,R=301]
# www -> apex
RewriteCond %{HTTP_HOST} ^www\.tavukcadiri\.com$ [NC]
RewriteRule ^ https://tavukcadiri.com%{REQUEST_URI} [L,R=301]

# ---- 404 ----
ErrorDocument 404 /404.html

# ---- Sikistirma ----
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>

# ---- Onbellek (gorseller ?v= ile versiyonlaniyor) ----
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType text/html "access plus 10 minutes"
ExpiresByType application/xml "access plus 1 day"
</IfModule>
